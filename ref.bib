	langid = {english},
	file = {Chen et al_2024_Knowledge-Informed Wheel Wear Prediction Method for High-Speed Train Using.pdf:D\:\\drive\\OneDrive - mails.tsinghua.edu.cn\\zotero_files\\files\\7、投稿\\7.1 SR OL PHM\\7.1.10Attention\\knowledge\\Chen et al_2024_Knowledge-Informed Wheel Wear Prediction Method for High-Speed Train Using.pdf:application/pdf},
