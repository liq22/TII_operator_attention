	note = {arXiv:2303.05517 [cs]
version: 1},
	keywords = {Computer Science - Artificial Intelligence, Computer Science - Machine Learning},
	file = {arXiv.org Snapshot:D\:\\software\\zotero\\files\\storage\\879HUBND\\2303.html:text/html;Solís-Martín et al_2023_On the Soundness of XAI in Prognostics and Health Management (PHM).pdf:D\:\\drive\\OneDrive - mails.tsinghua.edu.cn\\zotero_files\\files\\1. PHM\\1.1 故障诊断\\1.1.3 X diagnosis\\Solís-Martín et al_2023_On the Soundness of XAI in Prognostics and Health Management (PHM).pdf:application/pdf},
